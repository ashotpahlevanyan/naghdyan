---
import { getCollection } from 'astro:content';
import VideoCard from './VideoCard.tsx';
import { videoThumb, videoEmbedSrc } from '@lib/video';

const lectures = (await getCollection('lectures')).sort((a, b) => a.data.order - b.data.order);
---
<section class="band" id="lectures">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="kicker" data-lang-en>Lectures & talks</div><div class="kicker" data-lang-ru>Лекции и выступления</div><div class="kicker" data-lang-hy>Դասախոսություններ և ելույթներ</div>
      <h2 data-lang-en>Watch &amp; listen</h2><h2 data-lang-ru>Смотреть и слушать</h2><h2 data-lang-hy>Դիտե՛ք և լսե՛ք</h2>
      <p class="body" data-lang-en>Lectures, workshops, and conversations — YouTube and Vimeo. Click to play.</p>
      <p class="body" data-lang-ru>Лекции, семинары и беседы — YouTube и Vimeo. Нажмите, чтобы воспроизвести.</p>
      <p class="body" data-lang-hy>Դասախոսություններ, սեմինարներ և զրույցներ՝ YouTube և Vimeo։ Սեղմե՛ք դիտելու համար։</p>
    </div>
    <div class="lecture-grid">
      {
        lectures.map((l) => (
          <VideoCard
            client:visible
            embedSrc={videoEmbedSrc(l.data.video)}
            thumb={videoThumb(l.data.video)}
            tagEn={l.data.tag?.en}
            tagRu={l.data.tag?.ru}
            tagHy={l.data.tag?.hy}
            titleEn={l.data.title.en}
            titleRu={l.data.title.ru}
            titleHy={l.data.title.hy}
            descEn={l.data.description?.en}
            descRu={l.data.description?.ru}
            descHy={l.data.description?.hy}
          />
        ))
      }
    </div>
  </div>
</section>

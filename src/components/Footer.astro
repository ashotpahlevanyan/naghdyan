---
import Brand from './Brand.astro';
import { getSite } from '@lib/content';

const site = await getSite();
const { rights } = site.footer;
const { brand } = site;
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap foot-inner">
    <Brand href="/#top" />
    <div>
      <span data-lang-en>© {year} {brand.en} · naghdyan.com · {rights.en}</span>
      <span data-lang-ru>© {year} {brand.ru} · naghdyan.com · {rights.ru}</span>
    </div>
  </div>
</footer>

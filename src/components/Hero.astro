---
import { getSite, getHome } from '@lib/content';
import { inline } from '@lib/richtext';

const site = await getSite();
const { hero } = await getHome();
const { brand, portrait } = site;
---
<section class="hero">
  <div class="wrap hero-grid">
    <div class="reveal">
      <span class="eyebrow" data-lang-en>{hero.eyebrow.en}</span>
      <span class="eyebrow" data-lang-ru>{hero.eyebrow.ru}</span>

      <h1 data-lang-en>{brand.en}</h1>
      <h1 data-lang-ru>{brand.ru}</h1>

      <p class="lede" data-lang-en set:html={inline(hero.lede.en)}></p>
      <p class="lede" data-lang-ru set:html={inline(hero.lede.ru)}></p>

      <div class="hero-tags">
        {
          hero.tags.map((tag) => (
            <>
              <span class="tag" data-lang-en>{tag.en}</span>
              <span class="tag" data-lang-ru>{tag.ru}</span>
            </>
          ))
        }
      </div>

      <div class="cta-row">
        <a class="btn btn-primary" href="/#books">
          <span data-lang-en>{hero.ctaPrimary.en}</span><span data-lang-ru>{hero.ctaPrimary.ru}</span> →
        </a>
        <a class="btn btn-ghost" href="/#contact">
          <span data-lang-en>{hero.ctaSecondary.en}</span><span data-lang-ru>{hero.ctaSecondary.ru}</span>
        </a>
      </div>
    </div>

    <div class="portrait reveal">
      {
        portrait ? (
          <img src={portrait} alt={brand.en} />
        ) : (
          <div class="ph">
            <b>RN</b>
            <span data-lang-en>Add a portrait photo in the CMS (Site content → Branding).</span>
            <span data-lang-ru>Добавьте фотографию в CMS (Site content → Branding).</span>
          </div>
        )
      }
    </div>
  </div>
</section>

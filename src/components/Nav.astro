---
import Brand from './Brand.astro';
import LangToggle from './LangToggle.tsx';

/**
 * Sticky top navigation. Links are absolute (`/#about`) so they work from the
 * book detail pages too. The EN/RU switch is the only interactive island.
 */
const links = [
  { href: '/#about', en: 'About', ru: 'Обо мне', hy: 'Իմ մասին' },
  { href: '/#psychoontology', en: 'Psychoontology', ru: 'Психоонтология', hy: 'Հոգեոնտոլոգիա' },
  { href: '/#books', en: 'Books', ru: 'Книги', hy: 'Գրքեր' },
  { href: '/#articles', en: 'Articles', ru: 'Статьи', hy: 'Հոդվածներ' },
  { href: '/#lectures', en: 'Lectures', ru: 'Лекции', hy: 'Դասախոսություններ' },
  { href: '/#contact', en: 'Contact', ru: 'Контакты', hy: 'Կապ' },
];
---
<header class="nav">
  <div class="wrap nav-inner">
    <Brand href="/#top" compact />
    <nav class="nav-links">
      {
        links.map((l) => (
          <>
            <a href={l.href} data-lang-en>{l.en}</a>
            <a href={l.href} data-lang-ru>{l.ru}</a>
            <a href={l.href} data-lang-hy>{l.hy}</a>
          </>
        ))
      }
    </nav>
    <LangToggle client:load />
  </div>
</header>

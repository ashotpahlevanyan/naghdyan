---
import { getCollection } from 'astro:content';
import BookCard from './BookCard.astro';

const books = (await getCollection('books')).sort((a, b) => a.data.order - b.data.order);
---
<section class="band" id="books">
  <div class="wrap">
    <div class="sec-head between reveal">
      <div>
        <div class="kicker" data-lang-en>Books</div><div class="kicker" data-lang-ru>Книги</div><div class="kicker" data-lang-hy>Գրքեր</div>
        <h2 data-lang-en>Published & in progress</h2><h2 data-lang-ru>Изданное и в работе</h2><h2 data-lang-hy>Հրատարակված և ընթացքի մեջ</h2>
      </div>
      <p class="body" data-lang-en>Select a title to open its page — with images and a full description.</p>
      <p class="body" data-lang-ru>Выберите книгу, чтобы открыть её страницу с изображениями и полным описанием.</p>
      <p class="body" data-lang-hy>Ընտրե՛ք գիրքը՝ բացելու նրա էջը՝ պատկերներով և ամբողջական նկարագրությամբ։</p>
    </div>
    <div class="book-grid">
      {books.map((book) => <BookCard book={book} />)}
    </div>
  </div>
</section>
